def first_existing(paths: List[str]) -> str:
    for p in paths:
        if os.path.exists(p):
            return p
    raise FileNotFoundError(f"None of these paths exist: {paths}")


def calculate_sharpe(signals: np.ndarray, returns: np.ndarray, periods_per_year: int = BARSPERYEAR) -> float:
    pnl = signals * returns
    mu = pnl.mean()
    sig = pnl.std()
    if sig < 1e-12:
        return 0.0
    return float((mu / sig) * np.sqrt(periods_per_year))


def purge_between(mask_left: np.ndarray, mask_right: np.ndarray, purge_bars: int) -> Tuple[np.ndarray, np.ndarray]:
    left_idx = np.where(mask_left)[0]
    right_idx = np.where(mask_right)[0]
    if len(left_idx) == 0 or len(right_idx) == 0:
        return mask_left, mask_right
    last_left = left_idx[-1]
    first_right = right_idx[0]
    gap = max(0, purge_bars - (first_right - last_left - 1))
    if gap > 0:
        # drop from both ends symmetrically when possible
        drop_left = gap // 2
        drop_right = gap - drop_left
        if drop_left > 0:
            mask_left[max(0, last_left - drop_left + 1):last_left + 1] = False
        if drop_right > 0:
            mask_right[first_right:min(len(mask_right), first_right + drop_right)] = False
    return mask_left, mask_right

# ============================================================
# 3. OHLC TRIPLE-BARRIER TARGETS (decision-aligned)
# ============================================================
def compute_ohlc_barrier_targets(
    open_: np.ndarray,
    high: np.ndarray,
    low: np.ndarray,
    close: np.ndarray,
    quality: Optional[np.ndarray] = None,
    k_tp: float = K_TP,
    k_sl: float = K_SL,
    max_hold: int = MAX_HOLD,
    atr_period: int = ATR_PERIOD,
) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    """
    Decision at bar t close. Entry at t+1 open. Evaluate path through next max_hold bars.
    Returns
    -------
    realized_ret : [T]
    sltp_targets : [T, 2]
    hold_targets : [T]
    """
    T = len(close)
    if T < atr_period + max_hold + 2:
        return (np.zeros(T, dtype=np.float32),
                np.column_stack([np.full(T, k_tp, dtype=np.float32), np.full(T, k_sl, dtype=np.float32)]),
                np.full(T, max_hold, dtype=np.float32))

    tr = np.maximum.reduce([
        high - low,
        np.abs(high - np.r_[close[0], close[:-1]]),
        np.abs(low - np.r_[close[0], close[:-1]])
    ])
    atr = pd.Series(tr).ewm(span=atr_period, adjust=False).mean().values.astype(np.float64)
    atr = np.maximum(atr, 1e-8)

    realized = np.zeros(T, dtype=np.float32)
    sltp = np.zeros((T, 2), dtype=np.float32)
    hold = np.full(T, max_hold, dtype=np.float32)

    qual = np.ones(T, dtype=np.float64) if quality is None else quality.astype(np.float64)

    for t in range(T - 1):
        entry_idx = min(t + 1, T - 1)
        entry = float(open_[entry_idx])
        if entry <= 0:
            entry = float(close[t])

        # punish synthetic sections a bit by widening effective barriers
        q_adj = 1.0 + max(0.0, 1.0 - qual[t]) * 0.35
        tp_mult = k_tp * q_adj
        sl_mult = k_sl * q_adj
        tp_lvl = entry + tp_mult * atr[t]
        sl_lvl = entry - sl_mult * atr[t]

        end_j = min(entry_idx + max_hold - 1, T - 1)
        outcome = (close[end_j] - entry) / max(entry, 1e-12)
        tp_obs, sl_obs = tp_mult, sl_mult
        hold_obs = max_hold

        for j in range(entry_idx, end_j + 1):
            hit_tp = high[j] >= tp_lvl
            hit_sl = low[j] <= sl_lvl
            if hit_tp and hit_sl:
                # pessimistic tie-break: assume SL first
                hit_tp = False
            if hit_tp:
                outcome = (tp_mult * atr[t]) / max(entry, 1e-12)
                hold_obs = j - entry_idx + 1
                sl_obs = max(0.3, sl_mult * hold_obs / max_hold)
                break
            if hit_sl:
                outcome = -(sl_mult * atr[t]) / max(entry, 1e-12)
                hold_obs = j - entry_idx + 1
                tp_obs = max(0.5, tp_mult * hold_obs / max_hold)
                break

        realized[t] = float(outcome)
        sltp[t, 0] = float(tp_obs)
        sltp[t, 1] = float(sl_obs)
        hold[t] = float(hold_obs)

    return realized, sltp, hold

