# 6. LOSS
# ============================================================
class TraderFirstLoss(nn.Module):
    def __init__(self, edge_threshold: float):
        super().__init__()
        self.edge_threshold = edge_threshold
        self.edge_return = edge_threshold
        self.spread = SPREAD_BPS * 1e-4
        self.lambda_pnl = 1.0
        self.lambda_edge = 0.35
        self.lambda_dir = 0.20
        self.lambda_size = 0.12
        self.lambda_sltp = 0.06
        self.lambda_hold = 0.04
        self.lambda_nonedge = 0.08
        self.lambda_gate_rate = 0.08
        self.lambda_tc = 0.30
        self.lambda_l2 = 0.01

    def forward(self,
                signal: torch.Tensor,
                gate: torch.Tensor,
                direction: torch.Tensor,
                size: torch.Tensor,
                sltp_pred: torch.Tensor,
                hold_pred: torch.Tensor,
                edge_logits: torch.Tensor,
                dir_logits: torch.Tensor,
                target_ret: torch.Tensor,
                sltp_tgt: torch.Tensor,
                hold_tgt: torch.Tensor,
                quality_w: torch.Tensor,
                prev_sig: Optional[torch.Tensor] = None):
        # all shapes [B,N] or [B,N,*]
        sig = signal.squeeze(-1)
        gate_v = gate.squeeze(-1)
        size_v = size.squeeze(-1)
        dir_v = direction.squeeze(-1)
        edge_log = edge_logits.squeeze(-1)
        dir_log = dir_logits.squeeze(-1)
        q = quality_w
        ret = target_ret

        net_ret = ret - self.spread * torch.sign(sig) * (sig.abs() > 1e-6).float()
        pnl = sig * net_ret
        pnl_loss = -(pnl * q).mean()

        edge_target = (ret.abs() > self.edge_return).float()
        dir_target = (ret > 0).float()
        size_target = ((ret.abs() - self.edge_return).clamp(min=0.0) / (self.edge_return * 2.5 + 1e-8)).clamp(0.0, 1.0)
        size_target = size_target * edge_target

        with torch.amp.autocast(device_type=signal.device.type, enabled=False):
            edge_bce = F.binary_cross_entropy_with_logits(edge_log.float(), edge_target.float(), weight=(0.5 + q).float())
            # direction only matters on edge bars
            dir_w = (0.1 + edge_target + q).float() * (edge_target > 0).float()
            dir_bce = F.binary_cross_entropy_with_logits(dir_log.float(), dir_target.float(), weight=dir_w)

        size_loss = F.smooth_l1_loss(size_v * edge_target, size_target, reduction='none')
        size_loss = (size_loss * (0.5 + q)).mean()

        sltp_loss = F.smooth_l1_loss(sltp_pred, sltp_tgt, reduction='none').mean(dim=-1)
        sltp_loss = (sltp_loss * edge_target * (0.5 + q)).mean()

        hold_scaled_tgt = hold_tgt / float(MAX_HOLD)
        hold_scaled_pred = hold_pred.squeeze(-1) / float(MAX_HOLD)
        hold_loss = F.smooth_l1_loss(hold_scaled_pred, hold_scaled_tgt, reduction='none')
        hold_loss = (hold_loss * edge_target * (0.5 + q)).mean()

        # discourage trading on non-edge bars
        nonedge_pen = (gate_v * (1.0 - edge_target) * (0.5 + q)).mean()
        gate_rate = gate_v.mean()
        gate_rate_pen = (gate_rate - TARGET_GATE_RATE).abs()

        if prev_sig is not None and prev_sig.shape == sig.shape:
            tc = (sig - prev_sig).abs().mean() * self.spread
        else:
            tc = sig.abs().mean() * self.spread

        l2 = (sig ** 2).mean()

        loss = (
            self.lambda_pnl * pnl_loss
            + self.lambda_edge * edge_bce
            + self.lambda_dir * dir_bce
            + self.lambda_size * size_loss
            + self.lambda_sltp * sltp_loss
            + self.lambda_hold * hold_loss
            + self.lambda_nonedge * nonedge_pen
            + self.lambda_gate_rate * gate_rate_pen
            + self.lambda_tc * tc
            + self.lambda_l2 * l2
        )
        return loss

