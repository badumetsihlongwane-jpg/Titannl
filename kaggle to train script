class DecisionForexDataset(Dataset):
    def __init__(self, X: np.ndarray, rets: np.ndarray, sltp: np.ndarray, hold: np.ndarray,
                 quality: np.ndarray, chunk_len: int):
        self.X = torch.tensor(X, dtype=torch.float32)
        self.rets = torch.tensor(rets, dtype=torch.float32)
        self.sltp = torch.tensor(sltp, dtype=torch.float32)
        self.hold = torch.tensor(hold, dtype=torch.float32)
        self.quality = torch.tensor(quality, dtype=torch.float32)
        self.chunk_len = chunk_len
        self.n_chunks = max(0, len(X) - chunk_len + 1)

    def __len__(self) -> int:
        return self.n_chunks

    def __getitem__(self, idx: int):
        s = idx
        e = idx + self.chunk_len
        # one decision on the last bar of chunk
        return (self.X[s:e],
                self.rets[e - 1],
                self.sltp[e - 1],
                self.hold[e - 1],
                self.quality[e - 1])

