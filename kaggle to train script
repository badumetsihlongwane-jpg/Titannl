def _find_dataset() -> str:
    candidates = [
        '/kaggle/working/Titan15M_Dataset.csv',
        '/kaggle/input/titanfx/Titan15M_Dataset.csv',
        './Titan15M_Dataset.csv',
        '/kaggle/working/Titan30M_Dataset.csv',
        '/kaggle/input/titanfx/Titan30M_Dataset.csv',
        './Titan30M_Dataset.csv',
    ]
    return first_existing(candidates)


def load_titan_dataset(path: str):
    if not os.path.exists(path):
        path = _find_dataset()

    print(f"\n>>> Loading {os.path.basename(path)} ...")
    df = pd.read_csv(path, index_col=0, parse_dates=True).sort_index()
    print(f"    Shape: {df.shape} | {df.index.min()} → {df.index.max()}")

    numeric_cols = set(df.select_dtypes(include=[np.number]).columns)

    # drop low-info / broken columns
    low_info = []
    for c in list(df.columns):
        if c not in numeric_cols:
            continue
        vals = pd.Series(df[c]).replace([np.inf, -np.inf], np.nan).dropna()
        nunique = vals.nunique(dropna=True)
        std = float(vals.std()) if len(vals) else 0.0
        if nunique <= 1 or std < 1e-10:
            low_info.append(c)
    if low_info:
        df = df.drop(columns=low_info)
        print(f"    Dropped {len(low_info)} low-information columns (examples: {low_info[:8]})")

    numeric_cols = set(df.select_dtypes(include=[np.number]).columns)
    quality_cols = [f'{p}_quality' for p in PAIRS if f'{p}_quality' in df.columns]
    if not quality_cols:
        for p in PAIRS:
            df[f'{p}_quality'] = 1.0
        quality_cols = [f'{p}_quality' for p in PAIRS]

    shared_cols = [
        c for c in df.columns
        if c in numeric_cols and not any(c.startswith(p) for p in PAIRS) and not c.startswith('target_')
    ]

    node_cols_map: Dict[str, List[str]] = {}
    node_arrays = []
    quality_arrs = []
    future_rets, sltp_list, hold_list = [], [], []

    for p in PAIRS:
        pair_cols = [c for c in df.columns if c in numeric_cols and c.startswith(p) and not c.startswith('target_')]
        # do not duplicate the quality column inside local feature block; keep it last as shared-ish per node if needed?
        pair_cols = [c for c in pair_cols if c != f'{p}_quality']
        node_cols_map[p] = pair_cols + shared_cols
        quality = df[f'{p}_quality'].fillna(1.0).values.astype(np.float32)
        quality_arrs.append(quality)

        close = df[f'{p}_Close'].ffill().bfill().values.astype(np.float64)
        open_ = df[f'{p}_Open'].ffill().bfill().values.astype(np.float64)
        high = df[f'{p}_High'].ffill().bfill().values.astype(np.float64)
        low = df[f'{p}_Low'].ffill().bfill().values.astype(np.float64)
        rets, sltp, hold = compute_ohlc_barrier_targets(open_, high, low, close, quality)
        future_rets.append(rets)
        sltp_list.append(sltp)
        hold_list.append(hold)
        pos = (rets > 0).mean() * 100
        neg = (rets < 0).mean() * 100
        zer = (rets == 0).mean() * 100
        print(f"    [{p}] OHLC barrier: std={rets.std():.5f} | pos={pos:.1f}% | neg={neg:.1f}% | zero={zer:.1f}% | hold={hold.mean():.2f}")

        node_arrays.append(df[node_cols_map[p]].fillna(0.0).values.astype(np.float32))

    min_feats = min(a.shape[1] for a in node_arrays)
    node_arrays = [a[:, :min_feats] for a in node_arrays]
    master = np.stack(node_arrays, axis=1).astype(np.float32)
    future_rets = np.stack(future_rets, axis=1).astype(np.float32)
    sltp_all = np.stack(sltp_list, axis=1).astype(np.float32)
    hold_all = np.stack(hold_list, axis=1).astype(np.float32)
    quality_all = np.stack(quality_arrs, axis=1).astype(np.float32)

    # save schema for backtest
    schema = {
        'pairs': PAIRS,
        'feats_per_node': int(min_feats),
        'node_cols': {p: node_cols_map[p][:min_feats] for p in PAIRS},
        'shared_cols': shared_cols,
        'local_feat_dim': len([c for c in node_cols_map[PAIRS[0]][:min_feats] if c.startswith(PAIRS[0])]),
        'shared_feat_dim': min_feats - len([c for c in node_cols_map[PAIRS[0]][:min_feats] if c.startswith(PAIRS[0])]),
        'max_hold': MAX_HOLD,
    }
    with open('titan_feature_schema.json', 'w') as f:
        json.dump(schema, f)

    print(f"    Master tensor: {master.shape} | feats/node: {min_feats}")
    print(f"    Shared cols: {len(shared_cols)} | examples: {shared_cols[:10]}")
    print("    Mean quality weight by pair: " + ", ".join([f"{p}={quality_all[:,i].mean():.3f}" for i, p in enumerate(PAIRS)]))
    return master, future_rets, sltp_all, hold_all, quality_all, min_feats, df.index, schema

# ============================================================
# 8. TRAIN / EVAL
# ============================================================
def split_and_scale(master, rets, sltp, hold, quality, dates):
    train_mask = (dates >= TRAIN_START) & (dates <= TRAIN_END)
    val_mask = (dates >= VAL_START) & (dates <= VAL_END)
    calib_mask = (dates >= CALIB_START) & (dates <= CALIB_END)
    backtest_mask = (dates >= BACKTEST_START) & (dates <= BACKTEST_END)

    train_mask, val_mask = purge_between(train_mask.copy(), val_mask.copy(), PURGE_BARS)
    val_mask, calib_mask = purge_between(val_mask.copy(), calib_mask.copy(), PURGE_BARS)
    calib_mask, backtest_mask = purge_between(calib_mask.copy(), backtest_mask.copy(), PURGE_BARS)

    train_idx = np.where(train_mask)[0]
    val_idx = np.where(val_mask)[0]
    calib_idx = np.where(calib_mask)[0]
    backtest_idx = np.where(backtest_mask)[0]

    scaler = RobustScaler().fit(master[train_idx].reshape(-1, master.shape[-1]))
    scaled = np.nan_to_num(
        scaler.transform(master.reshape(-1, master.shape[-1])).reshape(master.shape),
        nan=0.0, posinf=5.0, neginf=-5.0
    )
    with open('titan_scaler.pkl', 'wb') as f:
        pickle.dump(scaler, f)

    return scaled, train_idx, val_idx, calib_idx, backtest_idx


def train_epoch(model, loader, criterion, optimizer, amp_scaler, device):
    model.train()
    total_loss = 0.0
    total_pnl = 0.0
    n = 0
    # Training batches are shuffled, so carrying prev_sig across batches would create
    # a meaningless turnover penalty. We therefore disable cross-batch prev_sig in training.
    use_amp = device.type == 'cuda'

    for x, r, sltp, hold, q in loader:
        x, r, sltp, hold, q = x.to(device), r.to(device), sltp.to(device), hold.to(device), q.to(device)
        x = torch.clamp(x + torch.randn_like(x) * NOISE_STD, -8.0, 8.0)
        optimizer.zero_grad(set_to_none=True)
        if use_amp:
            with torch.amp.autocast('cuda'):
                signal, gate, direction, size, sltp_pred, hold_pred, edge_logits, dir_logits = model(x)
                loss = criterion(signal, gate, direction, size, sltp_pred, hold_pred, edge_logits, dir_logits,
                                 r, sltp, hold, q, prev_sig=None)
            amp_scaler.scale(loss).backward()
            amp_scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            amp_scaler.step(optimizer)
            amp_scaler.update()
        else:
            signal, gate, direction, size, sltp_pred, hold_pred, edge_logits, dir_logits = model(x)
            loss = criterion(signal, gate, direction, size, sltp_pred, hold_pred, edge_logits, dir_logits,
                             r, sltp, hold, q, prev_sig=None)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()

        total_loss += float(loss.item())
        total_pnl += float((signal.squeeze(-1) * r).mean().item())
        n += 1

    return total_loss / max(n, 1), total_pnl / max(n, 1)


@torch.no_grad()
def evaluate(model, loader, criterion, device):
    model.eval()
    total_loss = 0.0
    sigs, rets, gates, sizes, quals = [], [], [], [], []
    prev_sig = None
    n = 0

    for x, r, sltp, hold, q in loader:
        x, r, sltp, hold, q = x.to(device), r.to(device), sltp.to(device), hold.to(device), q.to(device)
        signal, gate, direction, size, sltp_pred, hold_pred, edge_logits, dir_logits = model(x)
        loss = criterion(signal, gate, direction, size, sltp_pred, hold_pred, edge_logits, dir_logits,
                         r, sltp, hold, q, prev_sig=prev_sig)
        prev_sig = signal.squeeze(-1)
        total_loss += float(loss.item())
        sigs.append(signal.squeeze(-1).cpu().numpy())
        rets.append(r.cpu().numpy())
        gates.append(gate.squeeze(-1).cpu().numpy())
        sizes.append(size.squeeze(-1).cpu().numpy())
        quals.append(q.cpu().numpy())
        n += 1

    if n == 0:
        empty = np.zeros((0, NUM_NODES), dtype=np.float32)
        return 0.0, 0.0, empty, empty, empty, empty, empty

    sig_arr = np.concatenate(sigs, axis=0)
    ret_arr = np.concatenate(rets, axis=0)
    gate_arr = np.concatenate(gates, axis=0)
    size_arr = np.concatenate(sizes, axis=0)
    qual_arr = np.concatenate(quals, axis=0)
    sharpe = calculate_sharpe(sig_arr.flatten(), ret_arr.flatten(), BARSPERYEAR)
    return total_loss / max(n, 1), sharpe, sig_arr, ret_arr, gate_arr, size_arr, qual_arr

# ============================================================
# 9. MAIN
# ============================================================
def main():
    print("\n" + "=" * 60)
    print("TITAN-NL v7.5: Trader-First / Currency-Aware / Multi-Scale 15m")
    print("=" * 60)

    dataset_path = _find_dataset()
    master, future_returns, sltp_all, hold_all, quality_all, feats_per_node, dates, schema = load_titan_dataset(dataset_path)

    scaled, train_idx, val_idx, calib_idx, backtest_idx = split_and_scale(master, future_returns, sltp_all, hold_all, quality_all, dates)

    print(f"\n  Splits → Train: {len(train_idx):,} | Val: {len(val_idx):,} | Calib: {len(calib_idx):,} | Backtest: {len(backtest_idx):,} bars")
    print(f"  Purge bars between splits: {PURGE_BARS}")
    print(f"  Detected periodicity: {BARSPERYEAR} bars/year")

    # estimate edge threshold from train only
    train_abs_ret = np.abs(future_returns[train_idx].reshape(-1))
    edge_threshold = float(np.quantile(train_abs_ret, EDGE_QUANTILE) + EDGE_COST_BUFFER)
    print(f"  Edge threshold for gate target: {edge_threshold:.6f} (quantile={EDGE_QUANTILE:.2f}, cost buffer={EDGE_COST_BUFFER:.6f})")

    local_feat_dim = schema['local_feat_dim']
    shared_feat_dim = schema['shared_feat_dim']

    train_ds = DecisionForexDataset(scaled[train_idx], future_returns[train_idx], sltp_all[train_idx], hold_all[train_idx], quality_all[train_idx], CHUNK_LEN)
    val_ds   = DecisionForexDataset(scaled[val_idx], future_returns[val_idx], sltp_all[val_idx], hold_all[val_idx], quality_all[val_idx], CHUNK_LEN)
    calib_ds = DecisionForexDataset(scaled[calib_idx], future_returns[calib_idx], sltp_all[calib_idx], hold_all[calib_idx], quality_all[calib_idx], CHUNK_LEN)
    bt_ds    = DecisionForexDataset(scaled[backtest_idx], future_returns[backtest_idx], sltp_all[backtest_idx], hold_all[backtest_idx], quality_all[backtest_idx], CHUNK_LEN)

    print(f"  Chunks → Train: {len(train_ds)} | Val: {len(val_ds)} | Calib: {len(calib_ds)} | Backtest: {len(bt_ds)}")
    tr_rets = future_returns[train_idx]
    print(f"\n  Return stats (train):")
    print(f"    mean={tr_rets.mean():.6f} | std={tr_rets.std():.6f} | min={tr_rets.min():.4f} | max={tr_rets.max():.4f}")
    print(f"    non-zero={np.count_nonzero(tr_rets) / max(tr_rets.size, 1) * 100:.1f}% | avg quality={quality_all[train_idx].mean():.3f}")

    train_loader = DataLoader(train_ds, batch_size=16, shuffle=True, drop_last=False)
    val_loader   = DataLoader(val_ds, batch_size=32, shuffle=False)
    calib_loader = DataLoader(calib_ds, batch_size=32, shuffle=False)
    bt_loader    = DataLoader(bt_ds, batch_size=32, shuffle=False)

    model = CurrencyAwareTrader(feats_per_node, local_feat_dim, shared_feat_dim).to(DEVICE)
    total_params = sum(p.numel() for p in model.parameters())
    print(f"\n  Model Parameters: {total_params:,}")

    criterion = TraderFirstLoss(edge_threshold=edge_threshold)
    optimizer = optim.AdamW(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)
    amp_scaler = torch.amp.GradScaler('cuda') if DEVICE.type == 'cuda' else None

    best_val = float('inf')
    patience_ctr = 0
    save_name = 'Best_TITAN_V75_EXPLORATION.pth' if EXPLORATION_ONLY else 'Best_TITAN_V75.pth'

    print(f"\n{'='*60}")
    print(f"PHASE 1: Historical Calibration ({EPOCHS} epochs)")
    print(f"{'='*60}\n")

    for epoch in range(EPOCHS):
        tr_loss, tr_pnl = train_epoch(model, train_loader, criterion, optimizer, amp_scaler, DEVICE)
        val_loss, val_sharpe, sig_arr, ret_arr, gate_arr, size_arr, qual_arr = evaluate(model, val_loader, criterion, DEVICE)
        gate_util = float((gate_arr > 0.2).mean() * 100) if gate_arr.size else 0.0
        size_mean = float(size_arr.mean()) if size_arr.size else 0.0
        valq = float(qual_arr.mean()) if qual_arr.size else 0.0
        print(f"Epoch {epoch+1:02d}/{EPOCHS} | Loss {tr_loss:.4e}/{val_loss:.4e} | PnL/decision {tr_pnl*100:.4f}% | Val Sharpe {val_sharpe:.4f} | Gate>0.2 {gate_util:.1f}% | Size {size_mean:.3f} | ValQ {valq:.3f}")

        if val_loss < best_val:
            best_val = val_loss
            patience_ctr = 0
            torch.save(model.state_dict(), save_name)
            print(f"  >> Best model saved → {save_name}")
        else:
            patience_ctr += 1
            if patience_ctr >= PATIENCE:
                print(f"\n  Early stop at epoch {epoch+1}")
                break

    print("\n" + "=" * 60)
    print("PHASE 2: Walk-Forward Calibration + Backtest")
    print("=" * 60)

    model.load_state_dict(torch.load(save_name, map_location=DEVICE))

    # conservative calibration: only decision heads
    for p in model.parameters():
        p.requires_grad = False
    trainable_modules = [model.edge_head, model.dir_head, model.size_head, model.tp_head, model.sl_head, model.hold_head]
    for mod in trainable_modules:
        for p in mod.parameters():
            p.requires_grad = True

    calib_opt = optim.AdamW(filter(lambda p: p.requires_grad, model.parameters()), lr=LR * 0.25, weight_decay=1e-4)

    print("  [1/3] Priming on train data...")
    evaluate(model, train_loader, criterion, DEVICE)
    print("  [2/3] Priming on val data...")
    evaluate(model, val_loader, criterion, DEVICE)
    print(f"  [3/3] Calibration window ({CALIB_START} – {CALIB_END})...")

    model.train()
    calib_pnls = []
    for x, r, sltp, hold, q in calib_loader:
        x, r, sltp, hold, q = x.to(DEVICE), r.to(DEVICE), sltp.to(DEVICE), hold.to(DEVICE), q.to(DEVICE)
        calib_opt.zero_grad(set_to_none=True)
        signal, gate, direction, size, sltp_pred, hold_pred, edge_logits, dir_logits = model(x)
        loss = criterion(signal, gate, direction, size, sltp_pred, hold_pred, edge_logits, dir_logits, r, sltp, hold, q)
        loss.backward()
        torch.nn.utils.clip_grad_norm_(filter(lambda p: p.requires_grad, model.parameters()), 0.75)
        calib_opt.step()
        calib_pnls.append(float((signal.squeeze(-1) * r).mean().item()))
    print(f"    Calibration avg PnL/decision: {np.mean(calib_pnls)*100 if calib_pnls else 0.0:.4f}%")

    print(f"\n  Backtesting ({BACKTEST_START} – {BACKTEST_END})...")
    bt_loss, bt_sharpe, sig_arr, ret_arr, gate_arr, size_arr, qual_arr = evaluate(model, bt_loader, criterion, DEVICE)

    n_bt = sig_arr.shape[0]
    gate_util = float((gate_arr > 0.2).mean() * 100) if gate_arr.size else 0.0
    avg_size = float(size_arr.mean()) if size_arr.size else 0.0
    avg_q = float(qual_arr.mean()) if qual_arr.size else 0.0
    print(f"\nBacktest: {n_bt} decisions | Portfolio Sharpe: {bt_sharpe:.4f} | Gate utilisation: {gate_util:.1f}% | Avg size: {avg_size:.3f} | Avg quality: {avg_q:.3f}\n")
    print(f"  {'Pair':<8} {'Sharpe':>8} {'WinRate':>9} {'AvgSig':>8} {'AvgGate':>9} {'AvgSize':>9} {'PnL%':>9}")
    print(f"  {'-'*64}")
    for i, pair in enumerate(PAIRS):
        ps = calculate_sharpe(sig_arr[:, i], ret_arr[:, i], BARSPERYEAR)
        wr = np.mean(np.sign(sig_arr[:, i]) == np.sign(ret_arr[:, i])) * 100
        avg_sig = np.abs(sig_arr[:, i]).mean()
        avg_gate = gate_arr[:, i].mean()
        avg_sz = size_arr[:, i].mean()
        cum_pnl_pct = (sig_arr[:, i] * ret_arr[:, i]).sum() * 100
        print(f"  {pair:<8} {ps:>8.3f} {wr:>8.1f}% {avg_sig:>8.4f} {avg_gate:>9.4f} {avg_sz:>9.4f} {cum_pnl_pct:>8.4f}%")

    torch.save({
        'model_state_dict': model.state_dict(),
        'config': {
            'pairs': PAIRS,
            'currencies': CURRENCIES,
            'local_feat_dim': local_feat_dim,
            'shared_feat_dim': shared_feat_dim,
            'feats_per_node': feats_per_node,
            'max_hold': MAX_HOLD,
            'chunk_len': CHUNK_LEN,
            'version': 'v7.5',
        }
    }, 'titan_v7_complete.pth')
    print("\nSaved `Best_TITAN_V75_EXPLORATION.pth` / `titan_v7_complete.pth` / `titan_scaler.pkl` / `titan_feature_schema.json`.")


if __name__ == '__main__':
    main()
