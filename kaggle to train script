# 5. MODEL
# ============================================================
class MultiScaleTemporalEncoder(nn.Module):
    def __init__(self, in_dim: int, hidden_dim: int):
        super().__init__()
        branch_dim = hidden_dim // 2
        self.proj = nn.Sequential(
            nn.Linear(in_dim, hidden_dim), nn.GELU(), nn.LayerNorm(hidden_dim)
        )
        self.fast_conv = nn.Conv1d(hidden_dim, branch_dim, kernel_size=3, padding=1)
        self.medium_conv = nn.Conv1d(hidden_dim, branch_dim, kernel_size=7, padding=3)
        self.fast_gru = nn.GRU(branch_dim, branch_dim, batch_first=True)
        self.medium_gru = nn.GRU(branch_dim, branch_dim, batch_first=True)
        self.attn = nn.MultiheadAttention(hidden_dim, num_heads=4, batch_first=True, dropout=0.1)
        self.ff = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim * 2), nn.GELU(), nn.Dropout(0.1),
            nn.Linear(hidden_dim * 2, hidden_dim)
        )
        self.norm1 = nn.LayerNorm(hidden_dim)
        self.norm2 = nn.LayerNorm(hidden_dim)
        self.out = nn.Sequential(nn.Linear(hidden_dim * 3, hidden_dim), nn.GELU(), nn.LayerNorm(hidden_dim))

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        # x: [B, S, F]
        h = self.proj(x)
        conv_in = h.transpose(1, 2)
        fast = F.gelu(self.fast_conv(conv_in)).transpose(1, 2)
        medium = F.gelu(self.medium_conv(conv_in)).transpose(1, 2)
        fast_seq, _ = self.fast_gru(fast)
        medium_seq, _ = self.medium_gru(medium)
        attn_out, _ = self.attn(h, h, h, need_weights=False)
        h = self.norm1(h + attn_out)
        h = self.norm2(h + self.ff(h))
        pooled = h[:, -1]
        return self.out(torch.cat([fast_seq[:, -1], medium_seq[:, -1], pooled], dim=-1))


class LocalTemporalEncoder(MultiScaleTemporalEncoder):
    def __init__(self, in_dim: int, hidden_dim: int = LOCAL_DIM):
        super().__init__(in_dim, hidden_dim)


class SharedTemporalEncoder(MultiScaleTemporalEncoder):
    def __init__(self, in_dim: int, hidden_dim: int = SHARED_DIM):
        super().__init__(in_dim, hidden_dim)


class CurrencyAwareTrader(nn.Module):
    def __init__(self, feats_per_node: int, local_feat_dim: int, shared_feat_dim: int):
        super().__init__()
        self.local_feat_dim = local_feat_dim
        self.shared_feat_dim = shared_feat_dim

        self.local_encoder = LocalTemporalEncoder(local_feat_dim, LOCAL_DIM)
        self.shared_encoder = SharedTemporalEncoder(shared_feat_dim, SHARED_DIM)

        self.to_currency = nn.Sequential(
            nn.Linear(LOCAL_DIM + SHARED_DIM, D_MODEL), nn.GELU(), nn.LayerNorm(D_MODEL),
            nn.Linear(D_MODEL, D_MODEL), nn.GELU(), nn.LayerNorm(D_MODEL)
        )
        self.currency_gate = nn.Sequential(nn.Linear(D_MODEL, D_MODEL // 2), nn.GELU(), nn.Linear(D_MODEL // 2, 1), nn.Sigmoid())

        pair_input_dim = LOCAL_DIM + SHARED_DIM + 3 * D_MODEL
        self.pair_mixer = nn.Sequential(
            nn.Linear(pair_input_dim, HIDDEN_DIM), nn.GELU(), nn.LayerNorm(HIDDEN_DIM),
            nn.Linear(HIDDEN_DIM, HIDDEN_DIM), nn.GELU(), nn.Dropout(0.10),
            nn.Linear(HIDDEN_DIM, HIDDEN_DIM), nn.GELU(), nn.LayerNorm(HIDDEN_DIM)
        )
        self.global_pair_proj = nn.Linear(D_MODEL, HIDDEN_DIM)
        self.cross_pair_attn = nn.MultiheadAttention(HIDDEN_DIM, num_heads=4, batch_first=True, dropout=0.1)
        self.post_pair = nn.Sequential(
            nn.Linear(HIDDEN_DIM, HIDDEN_DIM), nn.GELU(), nn.Dropout(0.1), nn.LayerNorm(HIDDEN_DIM)
        )

        self.edge_head = nn.Linear(HIDDEN_DIM, 1)
        self.dir_head  = nn.Linear(HIDDEN_DIM, 1)
        self.size_head = nn.Linear(HIDDEN_DIM, 1)
        self.tp_head   = nn.Sequential(nn.Linear(HIDDEN_DIM, 1), nn.Softplus())
        self.sl_head   = nn.Sequential(nn.Linear(HIDDEN_DIM, 1), nn.Softplus())
        self.hold_head = nn.Sequential(nn.Linear(HIDDEN_DIM, 1), nn.Softplus())

        self.max_size = 0.20
        self._init_weights()

    def _init_weights(self):
        for m in self.modules():
            if isinstance(m, nn.Linear):
                nn.init.xavier_uniform_(m.weight, gain=0.7)
                if m.bias is not None:
                    nn.init.zeros_(m.bias)
        nn.init.constant_(self.edge_head.bias, -1.6)
        nn.init.constant_(self.size_head.bias, -1.2)

    def build_currency_states(self, pair_local: torch.Tensor, shared_state: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
        B, N, _ = pair_local.shape
        device = pair_local.device
        curr_sum = torch.zeros(B, NUM_CURR, D_MODEL, device=device)
        curr_cnt = torch.zeros(B, NUM_CURR, 1, device=device)

        sh = shared_state.unsqueeze(1).expand(-1, N, -1)
        pair_for_curr = torch.cat([pair_local, sh], dim=-1)
        pair_curr_feat = self.to_currency(pair_for_curr)
        pair_curr_gate = self.currency_gate(pair_curr_feat)
        pair_curr_feat = pair_curr_feat * pair_curr_gate

        for i, p in enumerate(PAIRS):
            base, quote = PAIR_TO_CURR[p]
            bidx, qidx = CUR_IDX[base], CUR_IDX[quote]
            curr_sum[:, bidx] += pair_curr_feat[:, i]
            curr_sum[:, qidx] -= pair_curr_feat[:, i]
            curr_cnt[:, bidx] += 1
            curr_cnt[:, qidx] += 1

        curr_states = curr_sum / curr_cnt.clamp(min=1.0)
        global_curr = curr_states.mean(dim=1)
        return curr_states, global_curr

    def forward(self, x: torch.Tensor):
        B, S, N, Fdim = x.shape
        shared_seq = x[:, :, 0, self.local_feat_dim:]
        shared_state = self.shared_encoder(shared_seq)

        local_states = []
        for i in range(N):
            loc_seq = x[:, :, i, :self.local_feat_dim]
            local_states.append(self.local_encoder(loc_seq))
        pair_local = torch.stack(local_states, dim=1)

        curr_states, global_curr = self.build_currency_states(pair_local, shared_state)

        pair_feats = []
        for i, p in enumerate(PAIRS):
            base, quote = PAIR_TO_CURR[p]
            bidx, qidx = CUR_IDX[base], CUR_IDX[quote]
            pair_currency = torch.cat([
                curr_states[:, bidx],
                curr_states[:, qidx],
                curr_states[:, bidx] - curr_states[:, qidx],
            ], dim=-1)
            feat = torch.cat([pair_local[:, i], shared_state, pair_currency], dim=-1)
            pair_feats.append(feat)
        pair_feats = torch.stack(pair_feats, dim=1)

        h = self.pair_mixer(pair_feats)
        global_ctx = self.global_pair_proj(global_curr).unsqueeze(1).expand(-1, N, -1)
        attn_out, _ = self.cross_pair_attn(h + global_ctx, h + global_ctx, h, need_weights=False)
        h = self.post_pair(h + attn_out)

        edge_logits = self.edge_head(h)
        dir_logits  = self.dir_head(h)
        gate = torch.sigmoid(edge_logits)
        direction = torch.tanh(dir_logits)
        size = torch.sigmoid(self.size_head(h)) * self.max_size
        signal = gate * direction * size
        tp_mult = self.tp_head(h).clamp(0.5, 4.5)
        sl_mult = self.sl_head(h).clamp(0.3, 2.5)
        hold = self.hold_head(h).clamp(1.0, float(MAX_HOLD))
        sltp = torch.cat([tp_mult, sl_mult], dim=-1)
        return signal, gate, direction, size, sltp, hold, edge_logits, dir_logits

