    col = f'{name}_close'
    if series.empty:
        final[col] = 0.0
    else:
        final[col] = series.reindex(final.index, method='ffill').bfill().fillna(0.0)

# daily rates / index transforms
for base in list(MACRO_1H.keys()) + list(MACRO_1D.keys()):
    col = f'{base}_close'
    s = final[col].replace(0, np.nan).ffill().bfill()
    final[f'{base}_ret1']  = safe_logret(s, 1).astype('float32')
    final[f'{base}_ret4']  = safe_logret(s, 4).astype('float32')
    final[f'{base}_ret16'] = safe_logret(s, 16).astype('float32')
    final[f'{base}_z96']   = rolling_zscore(final[f'{base}_ret1'], 96).astype('float32')

# yield features (important to keep as changes, not log returns only)
for y in ['yield10y_close', 'yield3m_close', 'ust2y_fut_close']:
    if y in final.columns:
        final[f'{y}_chg1'] = final[y].diff().fillna(0.0).astype('float32')
        final[f'{y}_chg4'] = final[y].diff(4).fillna(0.0).astype('float32')

if 'yield10y_close' in final.columns and 'yield3m_close' in final.columns:
    final['yield_curve_10y_3m'] = (final['yield10y_close'] - final['yield3m_close']).astype('float32')
    final['yield_curve_10y_3m_z96'] = rolling_zscore(final['yield_curve_10y_3m'], 96).astype('float32')

# cross-asset composite features
final['riskoff_score'] = (
    + 0.35 * final.get('dxy_z96', 0.0)
    + 0.25 * final.get('vix_z96', 0.0)
    + 0.20 * final.get('gold_z96', 0.0)
    - 0.20 * final.get('sp500_z96', 0.0)
    - 0.10 * final.get('nikkei_z96', 0.0)
).astype('float32')

final['energy_stress'] = (
    0.65 * final.get('oil_z96', 0.0) + 0.35 * final.get('copper_z96', 0.0)
).astype('float32')

# Optional external daily geopolitics/oil regime features
if external_geo_daily is not None and not external_geo_daily.empty:
    geo_aligned = align_daily_to_intraday(external_geo_daily, final.index)
    final = final.join(geo_aligned, how='left')
    final['geo_available'] = 1.0
else:
    final['geo_available'] = 0.0

if 'geo_conflict_score' in final.columns:
    final['global_stress_score'] = (
        0.50 * final['riskoff_score']
        + 0.25 * final['energy_stress']
        + 0.25 * final['geo_conflict_score']
    ).astype('float32')
else:
    final['global_stress_score'] = (
        0.65 * final['riskoff_score'] + 0.35 * final['energy_stress']
    ).astype('float32')

# ── Pair directional / microstructure features ───────────────────────────────
print("\n>>> Computing pair-level features ...")
for pair in FOREX_TICKERS:
    o = final[f'{pair}_Open'].replace(0, np.nan).ffill()
    h = final[f'{pair}_High'].replace(0, np.nan).ffill()
    l = final[f'{pair}_Low'].replace(0, np.nan).ffill()
    c = final[f'{pair}_Close'].replace(0, np.nan).ffill()

    ret1  = safe_logret(c, 1)
    ret2  = safe_logret(c, 2)
    ret4  = safe_logret(c, 4)
    ret8  = safe_logret(c, 8)
    ret16 = safe_logret(c, 16)
    ret32 = safe_logret(c, 32)
    ret64 = safe_logret(c, 64)

    range_raw  = (h - l).fillna(0.0)
    body_raw   = (c - o).fillna(0.0)
    upper_wick = (h - np.maximum(o, c)).clip(lower=0).fillna(0.0)
    lower_wick = (np.minimum(o, c) - l).clip(lower=0).fillna(0.0)
    close_pos  = ((c - l) / (range_raw + 1e-10)).clip(0, 1).fillna(0.5) - 0.5

    atr14      = compute_atr(h, l, c, 14)
    atr14n     = (atr14 / (c + 1e-10)).fillna(0.0)
    vol10      = ret1.rolling(10).std().fillna(0.0)
    vol20      = ret1.rolling(20).std().fillna(0.0)
    vol_fast   = realized_vol(c, 8)
    vol_medium = realized_vol(c, 24)
    vol_slow   = realized_vol(c, 96)
    vol_ratio_fast_slow = (vol_fast / (vol_slow + 1e-10)).clip(0, 10).fillna(1.0)
    range20    = range_raw.rolling(20).mean().fillna(0.0)
    compress20 = (range_raw / (range20 + 1e-10)).clip(0, 10).fillna(1.0)

    ema8  = c.ewm(span=8, adjust=False).mean()
    ema21 = c.ewm(span=21, adjust=False).mean()
    ema55 = c.ewm(span=55, adjust=False).mean()
    ema_gap = ((ema8 - ema21) / (atr14 + 1e-10)).fillna(0.0)
    trend_stack = ((ema8 - ema55) / (atr14 + 1e-10)).fillna(0.0)

    rsi14     = compute_rsi(c, 14) / 100.0 - 0.5
    macdh     = compute_macd_hist(c)
    eff16     = trend_efficiency(c, 16)
    eff48     = trend_efficiency(c, 48)
    momage    = bars_since_sign_flip(ret1, scale=8.0)
    slope16   = rolling_slope(c, 16) / (atr14 + 1e-10)
    slope48   = rolling_slope(c, 48) / (atr14 + 1e-10)

    hi20 = h.rolling(20).max()
    lo20 = l.rolling(20).min()
    hi96 = h.rolling(96).max()
    lo96 = l.rolling(96).min()
    dist_hi20 = ((c - hi20) / (atr14 + 1e-10)).fillna(0.0)
    dist_lo20 = ((c - lo20) / (atr14 + 1e-10)).fillna(0.0)
    dist_hi96 = ((c - hi96) / (atr14 + 1e-10)).fillna(0.0)
    dist_lo96 = ((c - lo96) / (atr14 + 1e-10)).fillna(0.0)
    breakout_96 = ((c > hi96.shift(1)).astype(float) - (c < lo96.shift(1)).astype(float)).fillna(0.0)

    final[f'{pair}_ret1']      = ret1.astype('float32')
    final[f'{pair}_ret2']      = ret2.astype('float32')
    final[f'{pair}_ret4']      = ret4.astype('float32')
    final[f'{pair}_ret8']      = ret8.astype('float32')
    final[f'{pair}_ret16']     = ret16.astype('float32')
    final[f'{pair}_ret32']     = ret32.astype('float32')
    final[f'{pair}_ret64']     = ret64.astype('float32')
    final[f'{pair}_vol10']     = vol10.astype('float32')
    final[f'{pair}_vol20']     = vol20.astype('float32')
    final[f'{pair}_vol_fast']  = vol_fast.astype('float32')
    final[f'{pair}_vol_medium']= vol_medium.astype('float32')
    final[f'{pair}_vol_slow']  = vol_slow.astype('float32')
    final[f'{pair}_vol_ratio_fs'] = vol_ratio_fast_slow.astype('float32')
    final[f'{pair}_atr14raw']  = atr14.astype('float32')
    final[f'{pair}_atr14n']    = atr14n.astype('float32')
    final[f'{pair}_range_n']   = (range_raw / (c + 1e-10)).fillna(0.0).astype('float32')
    final[f'{pair}_body_n']    = (body_raw / (atr14 + 1e-10)).fillna(0.0).astype('float32')
    final[f'{pair}_upwick_n']  = (upper_wick / (atr14 + 1e-10)).fillna(0.0).astype('float32')
    final[f'{pair}_dnwick_n']  = (lower_wick / (atr14 + 1e-10)).fillna(0.0).astype('float32')
    final[f'{pair}_closepos']  = close_pos.astype('float32')
    final[f'{pair}_compress20']= compress20.astype('float32')
    final[f'{pair}_rsi14']     = rsi14.astype('float32')
    final[f'{pair}_macdh']     = macdh.astype('float32')
    final[f'{pair}_ema_gap']   = ema_gap.astype('float32')
    final[f'{pair}_trend_stack'] = trend_stack.astype('float32')
    final[f'{pair}_eff16']     = eff16.astype('float32')
    final[f'{pair}_eff48']     = eff48.astype('float32')
    final[f'{pair}_momage']    = momage.astype('float32')
    final[f'{pair}_slope16']   = slope16.astype('float32')
    final[f'{pair}_slope48']   = slope48.astype('float32')
    final[f'{pair}_dist_hi20'] = dist_hi20.astype('float32')
    final[f'{pair}_dist_lo20'] = dist_lo20.astype('float32')
    final[f'{pair}_dist_hi96'] = dist_hi96.astype('float32')
    final[f'{pair}_dist_lo96'] = dist_lo96.astype('float32')
    final[f'{pair}_breakout96']= breakout_96.astype('float32')

    # source-quality / synthetic-awareness features
    final[f'{pair}_quality'] = (
        0.10 + 0.45 * final[f'{pair}_is_true30m'] + 0.45 * final[f'{pair}_is_true15m']
    ).clip(0.10, 1.0).astype('float32')
    final[f'{pair}_parent_rng1h_n'] = (
        final[f'{pair}_parent_rng1h'] / (c + 1e-10)
    ).fillna(0.0).astype('float32')
    final[f'{pair}_parent_bdy1h_n'] = (
        final[f'{pair}_parent_bdy1h'] / (c + 1e-10)
    ).fillna(0.0).astype('float32')
    final[f'{pair}_synth_pressure'] = (1.0 - final[f'{pair}_quality']).astype('float32')
    final[f'{pair}_micro_regime'] = (0.40 * final[f'{pair}_vol_ratio_fs'] + 0.35 * final[f'{pair}_compress20'] + 0.25 * final[f'{pair}_trend_stack'].abs()).astype('float32')

    # simple future-return targets for diagnostics / optional supervised heads
    final[f'target_{pair}_ret_1']  = safe_logret(c.shift(-1), 0).astype('float32')
    final[f'target_{pair}_ret_4']  = safe_logret(c.shift(-4), 0).astype('float32')
    final[f'target_{pair}_ret_12'] = safe_logret(c.shift(-12), 0).astype('float32')

    print(f"  [{pair}] ret1_std={ret1.std():.6f} | vol20_mean={vol20.mean():.6f} | true15m={final[f'{pair}_is_true15m'].mean()*100:.1f}%")

# overwrite target calculations with proper future/log-return form
for pair in FOREX_TICKERS:
    c = final[f'{pair}_Close'].replace(0, np.nan).ffill()
    for h in [1, 4, 12]:
        final[f'target_{pair}_ret_{h}'] = np.log(c.shift(-h) / c).replace([np.inf, -np.inf], np.nan).fillna(0.0).astype('float32')

# ── Currency-strength features ────────────────────────────────────────────────
# Positive means currency strengthening.
final['USD_strength_1'] = ((
    -final['EURUSD_ret1'] - final['GBPUSD_ret1'] - final['AUDUSD_ret1'] + final['USDJPY_ret1']
) / 4.0).astype('float32')
final['USD_strength_4'] = ((
    -final['EURUSD_ret4'] - final['GBPUSD_ret4'] - final['AUDUSD_ret4'] + final['USDJPY_ret4']
) / 4.0).astype('float32')

final['EUR_strength_1'] = final['EURUSD_ret1'].astype('float32')
final['GBP_strength_1'] = final['GBPUSD_ret1'].astype('float32')
final['AUD_strength_1'] = final['AUDUSD_ret1'].astype('float32')
final['JPY_strength_1'] = (-final['USDJPY_ret1']).astype('float32')

# pair dispersion / correlation proxies
usd_pairs = ['EURUSD_ret1', 'GBPUSD_ret1', 'AUDUSD_ret1', 'USDJPY_ret1']
final['usd_pair_dispersion_20'] = final[usd_pairs].std(axis=1).rolling(20).mean().fillna(0.0).astype('float32')
final['fx_momentum_breadth'] = np.sign(final[usd_pairs]).mean(axis=1).fillna(0.0).astype('float32')

# Cross links to current macro regime
for pair in FOREX_TICKERS:
    final[f'{pair}_x_riskoff'] = (final[f'{pair}_ret1'] * final['riskoff_score']).astype('float32')
    final[f'{pair}_x_energy']  = (final[f'{pair}_ret1'] * final['energy_stress']).astype('float32')
    final[f'{pair}_x_dxy']     = (final[f'{pair}_ret1'] * final.get('dxy_z96', 0.0)).astype('float32')
    final[f'{pair}_x_gstress'] = (final[f'{pair}_ret1'] * final['global_stress_score']).astype('float32')

ret_cols = [f'{p}_ret1' for p in FOREX_TICKERS]
vol_cols = [f'{p}_vol_fast' for p in FOREX_TICKERS]
micro_cols = [f'{p}_micro_regime' for p in FOREX_TICKERS]
final = final.join(add_cross_asset_lag_features(final, ret_cols, 'fx_ret_cluster'))
final = final.join(add_cross_asset_lag_features(final, vol_cols, 'fx_vol_cluster'))
final['fx_micro_regime_mean'] = final[micro_cols].mean(axis=1).fillna(0.0).astype('float32')
final['fx_micro_regime_disp'] = final[micro_cols].std(axis=1).fillna(0.0).astype('float32')
final['global_regime_fast_medium'] = (final['fx_micro_regime_mean'] * (1.0 + final['riskoff_score'].abs())).astype('float32')

# ── Final clean-up ────────────────────────────────────────────────────────────
final.replace([np.inf, -np.inf], np.nan, inplace=True)
final.ffill(inplace=True)
final.bfill(inplace=True)
final.fillna(0.0, inplace=True)
final = final.astype('float32')

print(f"\n  Final shape : {final.shape[0]} rows x {final.shape[1]} cols")
print(f"  Date range  : {final.index[0]} -> {final.index[-1]}")
print(f"  NaN count   : {int(final.isna().sum().sum())}")

final.to_csv(OUT_PATH)
print(f"\n  Saved -> {OUT_PATH}")
print(f"\nTitan30M_Dataset.csv COMPLETE  ({final.shape[0]} 30m bars)")
print(f"  External geo columns present: {sum(c.startswith('geo_') for c in final.columns)}")
