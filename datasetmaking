# ── Download helper ───────────────────────────────────────────────────────────
def dl(ticker, start, end, interval, retries=MAX_RETRIES):
    fmt = '%Y-%m-%d'
    for at in range(1, retries + 1):
        try:
            raw = yf.download(
                ticker,
                start=start.strftime(fmt),
                end=end.strftime(fmt),
                interval=interval,
                progress=False,
                auto_adjust=True,
                threads=False,
            )
            if not raw.empty:
                if raw.index.tz is not None:
                    raw.index = raw.index.tz_convert('UTC').tz_localize(None)
                else:
                    raw.index = pd.to_datetime(raw.index).tz_localize(None)
                raw = raw.sort_index()
                if isinstance(raw.columns, pd.MultiIndex):
                    raw.columns = [c[0] for c in raw.columns]
                return raw
        except Exception as e:
            print(f"    [attempt {at}] {ticker} {interval}: {e}")
            if at < retries:
                time.sleep(4 * at)
    return pd.DataFrame()


def get_col(df, names, default=None):
    for name in names:
        if name in df.columns:
            return df[name]
    if default is not None:
        return pd.Series(default, index=df.index)
    return pd.Series(index=df.index, dtype='float64')


def get_close(df):
    return get_col(df, ['Close', 'close'])


# ── Synthetic 1h -> 15m conversion ────────────────────────────────────────────
def explode_1h_to_15m(df_1h: pd.DataFrame) -> pd.DataFrame:
    """
    Creates four synthetic 15m bars from each 1h bar.

    Important:
      We keep the intrabar path intentionally smooth so the training targets do not learn
      impossible microstructure from hourly candles. Parent range/body are preserved as
      separate context features, and true 30m / true 15m overlays replace these synthetic
      bars whenever recent Yahoo windows are available.
    """
    if df_1h.empty:
        return pd.DataFrame()

    out = []
    for ts, row in df_1h.iterrows():
        o = float(row['Open'])
        h = float(row['High'])
        l = float(row['Low'])
        c = float(row['Close'])
        path = np.linspace(o, c, 5)
        parent_range = max(h - l, 0.0)
        parent_body = abs(c - o)

        for step in range(4):
            left = float(path[step])
            right = float(path[step + 1])
            out.append((
                ts + pd.Timedelta(minutes=15 * step),
                {
                    'Open': left,
                    'High': max(left, right),
                    'Low': min(left, right),
                    'Close': right,
                    'Volume': np.nan,
                    'is_true_30m': 0.0,
                    'is_true_15m': 0.0,
                    'parent_range_1h': parent_range,
                    'parent_body_1h': parent_body,
                }
            ))

    out_df = pd.DataFrame([r for _, r in out], index=[i for i, _ in out]).sort_index()
    return out_df


# ── Feature helpers ───────────────────────────────────────────────────────────
def safe_logret(series, lag=1):
    s = series.replace(0, np.nan).ffill()
    return np.log(s / s.shift(lag)).replace([np.inf, -np.inf], np.nan).fillna(0.0)


def rolling_zscore(series, window=96):
    mu = series.rolling(window).mean()
    sd = series.rolling(window).std().replace(0, np.nan)
    return ((series - mu) / (sd + 1e-10)).clip(-8, 8).fillna(0.0)


def compute_rsi(close, period=14):
    delta = close.diff()
    gain  = delta.clip(lower=0).ewm(com=period - 1, adjust=False).mean()
    loss  = (-delta.clip(upper=0)).ewm(com=period - 1, adjust=False).mean()
    rs    = gain / (loss + 1e-10)
    return (100 - 100 / (1 + rs)).fillna(50.0)


def compute_atr(high, low, close, period=14):
    tr = pd.concat([
        high - low,
        (high - close.shift()).abs(),
        (low - close.shift()).abs()
    ], axis=1).max(axis=1)
    return tr.ewm(com=period - 1, adjust=False).mean().fillna(0.0)


def compute_macd_hist(close, fast=12, slow=26, sig=9):
    ema_f = close.ewm(span=fast, adjust=False).mean()
    ema_s = close.ewm(span=slow, adjust=False).mean()
    macd  = ema_f - ema_s
    sig_l = macd.ewm(span=sig, adjust=False).mean()
    return (macd - sig_l).fillna(0.0)


def trend_efficiency(close, lookback=16):
    net   = (close - close.shift(lookback)).abs()
    gross = close.diff().abs().rolling(lookback).sum()
    return (net / (gross + 1e-10)).clip(0, 1).fillna(0.0)


def bars_since_sign_flip(ret_series, scale=8.0):
    signs = np.sign(ret_series.replace(0, np.nan).ffill().fillna(0.0).values)
    out = np.zeros(len(signs), dtype=np.float32)
    ctr = 0
    for i in range(len(signs)):
        if i == 0 or signs[i] == signs[i - 1]:
            ctr += 1
        else:
            ctr = 1
        out[i] = np.tanh(ctr / scale)
    return pd.Series(out, index=ret_series.index)

def rolling_slope(series, window=16):
    def _slope(vals):
        vals = np.asarray(vals, dtype=np.float64)
        if np.isnan(vals).any():
            vals = pd.Series(vals).ffill().bfill().values
        x = np.arange(len(vals), dtype=np.float64)
        x = x - x.mean()
        y = vals - np.nanmean(vals)
        denom = np.dot(x, x)
        return 0.0 if denom <= 0 else float(np.dot(x, y) / denom)
    return series.rolling(window, min_periods=max(4, window // 3)).apply(_slope, raw=True).fillna(0.0)


def realized_vol(close, window):
    return safe_logret(close, 1).rolling(window).std().fillna(0.0)


def add_cross_asset_lag_features(df, cols, prefix):
    out = pd.DataFrame(index=df.index)
    for lag in [1, 4, 16]:
        lagged = df[cols].shift(lag)
        out[f'{prefix}_lag{lag}_mean'] = lagged.mean(axis=1).fillna(0.0).astype('float32')
        out[f'{prefix}_lag{lag}_disp'] = lagged.std(axis=1).fillna(0.0).astype('float32')
    return out


def add_time_features(df):
    idx = df.index
    hour_float = idx.hour + idx.minute / 60.0
    dow = idx.dayofweek.astype(float)

    df['hour_sin'] = np.sin(2 * np.pi * hour_float / 24.0).astype('float32')
    df['hour_cos'] = np.cos(2 * np.pi * hour_float / 24.0).astype('float32')
    df['dow_sin']  = np.sin(2 * np.pi * dow / 7.0).astype('float32')
    df['dow_cos']  = np.cos(2 * np.pi * dow / 7.0).astype('float32')

    df['is_monday']     = (idx.dayofweek == 0).astype('float32')
    df['is_friday']     = (idx.dayofweek == 4).astype('float32')
    df['is_month_end']  = idx.is_month_end.astype('float32')
    df['is_month_start']= idx.is_month_start.astype('float32')

    london = ((hour_float >= 7.0) & (hour_float < 16.0)).astype(np.float32)
    newyork = ((hour_float >= 13.0) & (hour_float < 22.0)).astype(np.float32)
    asia = (((hour_float >= 0.0) & (hour_float < 9.0))).astype(np.float32)
    overlap = ((hour_float >= 13.0) & (hour_float < 16.0)).astype(np.float32)

    df['session_asia']    = asia
    df['session_london']  = london
    df['session_newyork'] = newyork
    df['session_overlap'] = overlap
    return df


def first_bar_after_gap(index, min_gap_hours=8):
    delta_hours = pd.Series(index).diff().dt.total_seconds().div(3600).fillna(0.0)
    return (delta_hours >= min_gap_hours).astype(np.float32).values


def find_first_existing(paths):
    for p in paths:
        if p and os.path.exists(p):
            return p
    return None


def _normalize_event_type(val):
    s = str(val).strip().lower()
    if s in ('', 'nan', 'none', 'no_event', 'null'):
        return 'none'
    for old, new in [('/', '_'), (' ', '_'), ('-', '_'), ('&', 'and')]:
        s = s.replace(old, new)
    s = ''.join(ch for ch in s if ch.isalnum() or ch == '_')
    return s or 'none'


def load_external_geo_daily(main_path=None, timeline_path=None):
    """
    Load optional daily geopolitics/oil dataset and convert it to leak-safe daily features.
    Every daily field is shifted by 1 day before intraday expansion.
    """
    if main_path is None:
        main_path = find_first_existing(EXTERNAL_GEO_DAILY_CANDIDATES)
    if timeline_path is None:
        timeline_path = find_first_existing(EXTERNAL_GEO_TIMELINE_CANDIDATES)

    if main_path is None:
        return pd.DataFrame()

    print(f"\n>>> Loading external daily geopolitics data ...")
    print(f"  main file: {main_path}")
    raw = pd.read_csv(main_path)
    if 'date' not in raw.columns:
        print("  [WARN] external file has no 'date' column; skipping.")
        return pd.DataFrame()

    raw['date'] = pd.to_datetime(raw['date'], errors='coerce').dt.tz_localize(None).dt.normalize()
    raw = raw.dropna(subset=['date']).sort_values('date').drop_duplicates('date', keep='last')
    raw = raw.set_index('date')

    out = pd.DataFrame(index=raw.index)

    numeric_candidates = [
        'brent_price', 'wti_price', 'dxy_index', 'vix', 'gpr_index',
        'brent_return', 'wti_return', 'brent_wti_spread',
        'brent_volatility_7d', 'brent_volatility_30d',
        'wti_volatility_7d', 'wti_volatility_30d'
    ]
    for col in numeric_candidates:
        if col in raw.columns:
            out[f'geo_{col}'] = pd.to_numeric(raw[col], errors='coerce')

    if 'event_flag' in raw.columns:
        out['geo_event_flag'] = pd.to_numeric(raw['event_flag'], errors='coerce').fillna(0.0).clip(lower=0)

    if 'event_severity' in raw.columns:
        sev = raw['event_severity']
        if pd.api.types.is_numeric_dtype(sev):
            out['geo_event_severity'] = pd.to_numeric(sev, errors='coerce').fillna(0.0)
        else:
            sev_map = {
                'none': 0.0, 'low': 1.0, 'minor': 1.0, 'moderate': 2.0,
                'medium': 2.0, 'high': 3.0, 'severe': 4.0, 'critical': 5.0
            }
            out['geo_event_severity'] = sev.astype(str).str.lower().map(sev_map).fillna(0.0)

    if 'event_type' in raw.columns:
        evt = raw['event_type'].map(_normalize_event_type)
        common = evt[evt != 'none'].value_counts().head(6).index.tolist()
        out['geo_event_type_known'] = (evt != 'none').astype(float)
        for ev in common:
            out[f'geo_evt_{ev}'] = (evt == ev).astype(float)

    # Optional extra event timeline: daily counts by type
    if timeline_path is not None and os.path.exists(timeline_path):
        try:
            tl = pd.read_csv(timeline_path)
            if 'date' in tl.columns:
                tl['date'] = pd.to_datetime(tl['date'], errors='coerce').dt.tz_localize(None).dt.normalize()
                tl = tl.dropna(subset=['date']).sort_values('date')
                if 'event_type' in tl.columns:
                    tl['event_type'] = tl['event_type'].map(_normalize_event_type)
                    top_tl = tl[tl['event_type'] != 'none']['event_type'].value_counts().head(4).index.tolist()
                    per_day = pd.DataFrame(index=out.index)
                    per_day['geo_timeline_event_count'] = tl.groupby('date').size().reindex(out.index).fillna(0.0)
                    for ev in top_tl:
                        per_day[f'geo_tl_{ev}'] = (tl[tl['event_type'] == ev].groupby('date').size()
                                                   .reindex(out.index).fillna(0.0).clip(upper=1.0))
                    out = out.join(per_day, how='left')
        except Exception as e:
            print(f"  [WARN] failed to parse timeline file: {e}")

    # Shift all daily info by 1 full day for leak safety.
    out = out.shift(1)

    # Derived daily-regime features
    if 'geo_event_flag' in out.columns:
        ef = out['geo_event_flag'].fillna(0.0)
        out['geo_event_recent_3d'] = (ef.rolling(3, min_periods=1).max() > 0).astype(float)
        out['geo_event_recent_7d'] = (ef.rolling(7, min_periods=1).max() > 0).astype(float)
        out['geo_event_count_7d']  = ef.rolling(7, min_periods=1).sum().clip(0, 7)

    if 'geo_event_severity' in out.columns:
        out['geo_event_severity_7d'] = out['geo_event_severity'].fillna(0.0).rolling(7, min_periods=1).mean()

    for col in ['geo_gpr_index', 'geo_brent_return', 'geo_wti_return', 'geo_brent_wti_spread',
                'geo_brent_volatility_7d', 'geo_brent_volatility_30d',
                'geo_wti_volatility_7d', 'geo_wti_volatility_30d']:
        if col in out.columns:
            out[f'{col}_z30'] = rolling_zscore(out[col].ffill().bfill(), 30)

    # Composite stress scores from the external daily dataset
    gpr_part  = out.get('geo_gpr_index_z30', 0.0)
    evt_part  = out.get('geo_event_recent_7d', 0.0)
    sev_part  = out.get('geo_event_severity_7d', 0.0)
    oil_part  = out.get('geo_brent_return_z30', 0.0)
    vol_part  = out.get('geo_brent_volatility_7d_z30', 0.0)

    out['geo_conflict_score'] = (0.45 * gpr_part + 0.25 * evt_part + 0.15 * sev_part + 0.15 * vol_part)
    out['geo_oilshock_score'] = (0.60 * oil_part + 0.40 * vol_part)

    out.replace([np.inf, -np.inf], np.nan, inplace=True)
    out = out.ffill().bfill().fillna(0.0).astype('float32')
    print(f"  external daily features: {out.shape[1]} cols across {len(out)} days")
    return out


def align_daily_to_intraday(daily_df, intraday_index):
    if daily_df is None or daily_df.empty:
        return pd.DataFrame(index=intraday_index)
    aligned = daily_df.reindex(pd.DatetimeIndex(intraday_index.normalize()), method='ffill')
    aligned.index = intraday_index
    return aligned


